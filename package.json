{
  "name": "fhir-mern",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vijay-papanaboina/FHIR-MERN.git"
  },
  "license": "ISC",
  "scripts": {
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx}\" \"backend/src/**/*.ts\" \"shared/types/*.{ts,tsx,js}\" \"*.{json,md}\"",
    "postman:build": "node postman/scripts/build-collection.mjs",
    "seed": "npm run seed --workspace=backend",
    "check:commit": "npm run -w frontend lint && npm run -w @fhir-mern/shared build && npm run -w backend typecheck",
    "check:push": "npm run -w frontend build && npm run -w backend build && npm run -w frontend test && npm run -w backend test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
