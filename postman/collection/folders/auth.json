{
    "name": "Auth",
    "item": [
        {
            "name": "Get My Profile",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Origin",
                        "value": "{{origin}}"
                    }
                ],
                "url": {
                    "raw": "{{protocol}}://{{host}}/api/auth/me",
                    "protocol": "{{protocol}}",
                    "host": [
                        "{{host}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "me"
                    ]
                }
            }
        },
        {
            "name": "Sign Up",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Origin",
                        "value": "{{origin}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"{{example_email}}\",\n  \"password\": \"{{example_password}}\",\n  \"name\": \"{{example_name}}\"\n}"
                },
                "url": {
                    "raw": "{{protocol}}://{{host}}/api/auth/sign-up/email",
                    "protocol": "{{protocol}}",
                    "host": [
                        "{{host}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "sign-up",
                        "email"
                    ]
                }
            }
        },
        {
            "name": "Sign In",
            "request": {
                "method": "POST",
