                        "value": "{{origin}}"
                    }
                ],
                "url": {
                    "raw": "{{protocol}}://{{host}}/api/auth/sign-out",
                    "protocol": "{{protocol}}",
                    "host": [
                        "{{host}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "sign-out"
                    ]
                }
            }
        },
        {
            "name": "Get Session",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Origin",
                        "value": "{{origin}}"
                    }
                ],
                "url": {
                    "raw": "{{protocol}}://{{host}}/api/auth/session",
                    "protocol": "{{protocol}}",
                    "host": [
                        "{{host}}"
                    ],
