                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Origin",
                        "value": "{{origin}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"John Updated\"\n}"
                },
                "url": {
                    "raw": "{{protocol}}://{{host}}/api/auth/update-user",
                    "protocol": "{{protocol}}",
                    "host": [
                        "{{host}}"
                    ],
