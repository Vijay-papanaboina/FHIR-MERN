        {
            "name": "Alerts",
            "item": [
                {
                    "name": "SSE Stream",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/alerts/stream",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "alerts",
                                "stream"
                            ]
                        }
                    }
                },
                {
                    "name": "Get My Alerts",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/alerts",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "alerts"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Patient Alerts",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/alerts/patient/:patientFhirId",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "alerts",
                                "patient",
                                ":patientFhirId"
                            ],
                            "variable": [
                                {
                                    "key": "patientFhirId",
                                    "value": "1001"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Acknowledge Alert",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/alerts/:id/acknowledge",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "alerts",
                                ":id",
                                "acknowledge"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "alert-uuid"
                                }
                            ]
