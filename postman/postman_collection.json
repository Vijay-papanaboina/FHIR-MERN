                                "value": "{{origin}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{example_email}}\",\n  \"password\": \"{{example_password}}\"\n}"
                        },
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/auth/sign-in/email",
