{
    "info": {
        "name": "FHIR-MERN API",
        "description": "API collection for the current backend routes.\n\n### Environment Variables\n- `host`: backend host, e.g. `localhost:3000`\n- `protocol`: `http` or `https`\n- `origin`: frontend origin for Better Auth requests, e.g. `http://localhost:5173`",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Get My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Origin",
                                "value": "{{origin}}"
                            }
                        ],
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/auth/me",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        }
                    }
                },
                {
                    "name": "Sign Up",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Origin",
                                "value": "{{origin}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{example_email}}\",\n  \"password\": \"{{example_password}}\",\n  \"name\": \"{{example_name}}\"\n}"
                        },
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/auth/sign-up/email",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "sign-up",
                                "email"
                            ]
                        }
                    }
                },
                {
                    "name": "Sign In",
