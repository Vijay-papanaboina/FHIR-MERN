{
  "name": "fhir-backend",
  "version": "1.4.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run -w @fhir-mern/shared build",
    "dev": "tsx watch src/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run -w @fhir-mern/shared build && tsc",
    "start": "node dist/index.js",
    "typecheck": "npm run -w @fhir-mern/shared build && tsc --noEmit",
    "test:api": "vitest run tests/api",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:services": "npm run test:unit && npm run test:integration",
    "test": "npm run test:services && npm run test:api",
    "seed": "tsx scripts/seed-fhir.ts"
  },
  "dependencies": {
    "@fhir-mern/shared": "1.4.0",
    "better-auth": "^1.4.19",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.2.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
