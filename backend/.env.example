# Better-Auth Configuration
BETTER_AUTH_SECRET=dev-better-auth-secret-2026-0123456789
BETTER_AUTH_URL=http://localhost:3000
# Optional Better-Auth rate limit overrides
# Defaults:
# - test: disabled
# - development: enabled, 300 req / 60s
# - production: enabled, 60 req / 60s
# BETTER_AUTH_RATE_LIMIT_ENABLED=true
# BETTER_AUTH_RATE_LIMIT_WINDOW=60
# BETTER_AUTH_RATE_LIMIT_MAX=60
# Optional global API rate limit overrides (non-/api/auth routes)
# Defaults:
# - test: disabled
# - development: enabled, 300 req / 60s
# - production: enabled, 100 req / 60s
# GLOBAL_RATE_LIMIT_ENABLED=true
# GLOBAL_RATE_LIMIT_WINDOW=60
# GLOBAL_RATE_LIMIT_MAX=100
# Development-only hard bypass
# DISABLE_RATE_LIMIT=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional webhook request verification
WEBHOOK_SECRET=dev-webhook-secret-2026-0123456789ab
