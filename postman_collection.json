                            {
                                "key": "Origin",
                                "value": "{{origin}}"
                            }
                        ],
                        "url": {
                            "raw": "{{protocol}}://{{host}}/api/auth/me",
                            "protocol": "{{protocol}}",
                            "host": [
                                "{{host}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        }
                    }
                },
